<header>
  <h1>Add Tournament</h1>
  {{> logout }}
</header>
<div class="wrapper">
    <main class="admin">
        {{> adminNav id="add-tournament"}}
        <section>
            <form class="form-ajax" id="post-tournament" data-redirect="/tournaments" method="POST" action="/api/tournament">
                <input type="hidden" name="tenant_id" value="{{tenant_id}}">
                <fieldset id="tournament-fieldset">
                    {{> tournamentForm round="1" buyin="10" status="upcoming" seasons="seasons" players="players" tenant_id=tenant_id }}
                </fieldset>
            </form>
        </section>
    </main>
</div>
{{> footer tenant_id=tenant_id season_id=season_id view="admin"}}
