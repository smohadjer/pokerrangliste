<div class="row">
    <label>Season *</label>
    <select id="season_dropdown" required name="season_id">
    </select>
</div>
<div class="row">
    <label>Date *</label>
    <input required name="date" type="date" value="{{date}}"/>
</div>
<div class="row">
    <label>Round *</label>
    <select required name="round">
        <option {{#ifCond round '==' 1}}selected{{/ifCond}} value="1">1</option>
        <option {{#ifCond round '==' 2}}selected{{/ifCond}} value="2">2</option>
        <option {{#ifCond round '==' 3}}selected{{/ifCond}} value="3">3</option>
        <option {{#ifCond round '==' 4}}selected{{/ifCond}} value="4">4</option>
        <option {{#ifCond round '==' 5}}selected{{/ifCond}} value="5">5</option>
        <option {{#ifCond round '==' 6}}selected{{/ifCond}} value="6">6</option>
        <option {{#ifCond round '==' 7}}selected{{/ifCond}} value="7">7</option>
        <option {{#ifCond round '==' 8}}selected{{/ifCond}} value="8">8</option>
        <option {{#ifCond round '==' 9}}selected{{/ifCond}} value="9">9</option>
        <option {{#ifCond round '==' 10}}selected{{/ifCond}} value="10">10</option>
    </select>
</div>
<div class="row">
    <label>Buyin *</label>
    <input required name="buyin" type="number" value="{{buyin}}"/>
</div>
<div class="row">
    <label>Bounty Winner</label>
    <input name="bounty_winner">
</div>
<div class="row">
    <label>Bounty Prize</label>
    <input name="bountry_prize" type="number">
</div>
<div class="row">
    <label>Status {{status}}</label>
    <span>
        <input {{#ifCond status '==' 'upcoming'}} checked {{/ifCond}} name="status" id="upcoming" type="radio" value="upcoming"><label for="upcoming">Scheduled</label><br>
        <input {{#ifCond status '==' 'pending'}} checked {{/ifCond}} name="status" id="pending" type="radio" value="pending"><label for="pending">In-progress</label><br>
        <input  {{#ifCond status '==' 'done'}} checked {{/ifCond}} name="status" id="done" type="radio" value="done"><label  for="done">Completed</label>
    </span>
</div>
<div class="row">
    <label>Players count *</label>
    <select required name="count">
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
        <option value="5">5</option>
        <option value="6">6</option>
        <option value="7">7</option>
        <option value="8">8</option>
        <option value="9">9</option>
        <option value="10">10</option>
        <option value="11">11</option>
        <option value="12">12</option>
        <option value="13">13</option>
        <option value="14">14</option>
        <option value="15">15</option>
        <option value="16">16</option>
        <option value="17">17</option>
        <option value="18">18</option>
        <option value="19">19</option>
        <option value="20">20</option>
    </select>
</div>
<div id="players"></div>

<div class="submit">
    <button>Submit</button>
</div>
<p class="error"></p>
