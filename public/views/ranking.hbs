<header>
  <div class="flex">
    {{#if league_name}}
      <h3>{{league_name}}</h3>
    {{else}}
      <h3>turnies.de</h3>
    {{/if}}
    <h2>Ranking</h2>
    {{#if seasons}}
      <div>
        {{!-- <span class="label">Season</span> --}}
        {{> seasonSelector seasons=seasons season_id=season_id }}
      </div>
    {{/if}}
  </div>
</header>
<div class="wrapper">
  <table class="table-results">
    <tr>
        <th>R.</th>
        <th>Player</th>
        <th>Points</th>
        <th>1st</th>
        <th>Games</th>
        <!--<th>Rebuys</th>-->
    </tr>
    {{#each players}}
      <tr>
          <td>{{inc @index}}</td>
          <td class="name">
            {{#if ../season_id}}
              <a class="player-link" data-animation="slideInRTL" href="/profile?league_id={{../league_id}}&season_id={{../season_id}}&player_id={{this.id}}">
                <img class="player-thumbnail" src="/api/player-photo?player_id={{this.id}}&v={{this.photo_version}}" alt="" aria-hidden="true" onerror="this.onerror=null;this.src='/assets/players/default.png';">
                <span>{{this.name}}</span>
              </a>
            {{else}}
              <a class="player-link" data-animation="slideInRTL" href="/profile?league_id={{../league_id}}&player_id={{this.id}}">
                <img class="player-thumbnail" src="/api/player-photo?player_id={{this.id}}&v={{this.photo_version}}" alt="" aria-hidden="true" onerror="this.onerror=null;this.src='/assets/players/default.png';">
                <span>{{this.name}}</span>
              </a>
            {{/if}}
          </td>
          <td>{{this.points}}</td>
          <td>{{this.wins}}</td>
          <td>{{this.games}}</td>
          <!--<td>{{this.rebuys}}</td>-->
      </tr>
    {{/each}}
  </table>
  {{#ifCond players.length '==' 0}}
    <p style="text-align: center; margin: 3em; font-size: 24px;
    line-height: 1.3;">No tournament has been played in this season yet!</p>
  {{/ifCond}}
</div>
{{> footer league_id=league_id season_id=season_id view="ranking"}}
