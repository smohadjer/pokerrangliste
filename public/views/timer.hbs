<header>
  <div class="flex">
    {{#if league_name}}
      <h3>{{league_name}}</h3>
    {{else}}
      <h3>turnies.de</h3>
    {{/if}}
    <h2>Timer</h2>
    {{#if timers}}
      <span id="timer-selector">
        <select id="select-timer">
          {{#each timers}}
            <option
              {{#if this.selected}}selected="selected"{{/if}}
              value="{{this.id}}">{{this.name}}
            </option>
          {{/each}}
        </select>
      </span>
    {{else}}
      <h3></h3>
    {{/if}}
  </div>
</header>

<div class="wrapper">
  <main
    class="timer-page"
    data-timer-page
    data-timer-league-id="{{league_id}}"
    data-timer-id="{{timer.id}}"
    data-timer-default-duration="{{timer.duration}}"
    data-timer-small-blinds="{{timer.smallBlinds}}">
    <section class="timer-panel">
      <div class="timer-level">
        <div class="timer-round" data-timer-round>Level {{timer.initialRound}}</div>
        <div class="timer-blinds" data-timer-blinds>{{timer.initialBlinds}}</div>
      </div>
      <div class="timer-display" data-timer-display role="button" tabindex="0" aria-label="Start timer">{{timer.initialTime}}</div>
      <div class="timer-next-blinds" data-timer-next-blinds></div>
    </section>

    <section class="timer-controls">
      <div class="timer-actions">
        <div class="timer-round-control">
          <button type="button" data-timer-prev-level disabled>Prev Level</button>
        </div>
        <button class="timer-icon-button timer-icon-button--primary" type="button" aria-label="Start timer" data-timer-start>
          <img src="/images/play.svg" alt="" data-timer-start-icon>
        </button>
        <div class="timer-round-control">
          <button type="button" data-timer-next-level>Next Level</button>
        </div>
      </div>
      <div class="timer-secondary-actions">
        <button type="button" data-timer-reset-round>Reset Time</button>
        <button type="button" data-timer-reset-all>Restart</button>
        <button type="button" data-timer-blinds-structure-open>Blinds Structure</button>
      </div>
    </section>

    <div class="timer-wake-lock-popup" data-timer-wake-lock-message hidden>
      <div class="timer-wake-lock-popup__dialog">
        <p data-timer-wake-lock-text>Your browser cannot keep this screen awake. Disable auto-lock or screen timeout in your device settings while using the timer.</p>
        <div class="timer-wake-lock-popup__actions">
          <button type="button" data-timer-wake-lock-enable>Enable timer</button>
          <button type="button" data-timer-wake-lock-close>Close</button>
        </div>
      </div>
    </div>

    <div class="timer-wake-lock-popup" data-timer-blinds-structure-modal hidden>
      <div class="timer-wake-lock-popup__dialog timer-blinds-structure">
        <h2>Blinds Structure</h2>
        <div class="timer-blinds-structure__list" data-timer-blinds-structure-list></div>
        <button type="button" data-timer-blinds-structure-close>Close</button>
      </div>
    </div>
  </main>
</div>

{{> footer league_id=league_id season_id=season_id view="timer"}}
